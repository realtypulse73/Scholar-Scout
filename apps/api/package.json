{
  "name": "@scholarscout/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "prisma:generate": "prisma generate --schema ../../infra/db/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ../../infra/db/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ../../infra/db/schema.prisma",
    "prisma:seed": "ts-node ../../infra/db/seed.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --config jest.config.ts --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/platform-socket.io": "^10.4.2",
    "@nestjs/websockets": "^10.4.2",
    "@prisma/client": "^5.20.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.4",
    "jest": "^30.3.0",
    "prisma": "^5.20.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
