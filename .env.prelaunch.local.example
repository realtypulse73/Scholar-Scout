# ScholarScout local prelaunch workaround template
# Copy to .env.prelaunch.local and replace placeholders.
# Do not commit .env.prelaunch.local.

# For local rehearsal against a local/dev deployment, localhost is allowed.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-at-least-32-characters-local

# Temporary workaround only: lets readiness pass without OAuth for a local rehearsal.
# Do not use this for a public production launch unless intentionally accepted.
SCHOLARSCOUT_ALLOW_CREDENTIALS_ONLY_PRODUCTION=true

SCHOLARSCOUT_STAFF_EMAILS=staff@example.org
SCHOLARSCOUT_HEALTH_TOKEN=replace-with-health-token

# Local prelaunch workaround uses the HTTP fixture instead of Vercel Blob.
SCHOLARSCOUT_DATA_ADAPTER=http
SCHOLARSCOUT_DATA_SERVICE_URL=http://localhost:4010/scholarscout
SCHOLARSCOUT_DATA_SERVICE_TOKEN=local-service-token

SCHOLARSCOUT_SMOKE_BASE_URL=http://localhost:3000
SCHOLARSCOUT_SMOKE_HEALTH_TOKEN=replace-with-health-token
SCHOLARSCOUT_SMOKE_EXPECTED_ADAPTER=http
SCHOLARSCOUT_SMOKE_EXPECTED_PROVIDERS=
