{
  "name": "scholarscout",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "dev:web": "npm --workspace @scholarscout/web run dev",
    "build:web": "npm --workspace @scholarscout/web run build",
    "dev:api": "npm --workspace @scholarscout/api run start:dev",
    "build:api": "npm --workspace @scholarscout/api run build",
    "dev:admin": "npm --workspace @scholarscout/admin run dev",
    "build:admin": "npm --workspace @scholarscout/admin run build",
    "prisma:generate": "npm --workspace @scholarscout/api run prisma:generate",
    "prisma:migrate": "npm --workspace @scholarscout/api run prisma:migrate",
    "prisma:seed": "npm --workspace @scholarscout/api run prisma:seed"
  }
}
