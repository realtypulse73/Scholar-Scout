{
  "name": "scholar-scout",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @scholar-scout/web",
    "dev:web": "npm run dev --workspace @scholar-scout/web",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @scholar-scout/web",
    "build:vercel": "npm run build --workspace @scholar-scout/web",
    "vercel:docker-free": "npm install --ignore-scripts && npm run build:vercel",
    "build:apps": "npm run build --workspace @scholar-scout/web",
    "lint": "npm run lint --workspaces --if-present",
    "check:production-env": "node scripts/production-env-check.mjs",
    "provision:env": "node scripts/provision-environment.mjs",
    "provision:production-values": "node scripts/provision-production-values.mjs",
    "rehearse:prelaunch": "node scripts/prelaunch-rehearsal.mjs",
    "report:production": "node scripts/production-report-summary.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "test:production-tooling": "node --test scripts/test-production-tooling.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
