# ScholarScout production environment template
# Copy names into the hosting provider or GitHub Actions secrets.
# Do not commit real values.

NEXTAUTH_URL=https://scholarscout.example.org
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# OAuth providers are optional individually, but production should configure at least one.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated staff emails that should receive staff access after OAuth sign-in.
SCHOLARSCOUT_STAFF_EMAILS=staff@example.org

# Durable data store. Use either vercel-blob or http for production.
SCHOLARSCOUT_DATA_ADAPTER=vercel-blob
SCHOLARSCOUT_BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token
SCHOLARSCOUT_BLOB_DATA_PATH=scholarscout/data.json

# HTTP adapter alternative.
SCHOLARSCOUT_DATA_SERVICE_URL=
SCHOLARSCOUT_DATA_SERVICE_TOKEN=

# Service-token monitoring.
SCHOLARSCOUT_HEALTH_TOKEN=replace-with-health-token
SCHOLARSCOUT_SMOKE_BASE_URL=https://scholarscout.example.org
SCHOLARSCOUT_SMOKE_HEALTH_TOKEN=replace-with-health-token
SCHOLARSCOUT_SMOKE_EXPECTED_ADAPTER=vercel-blob
SCHOLARSCOUT_SMOKE_EXPECTED_PROVIDERS=google
SCHOLARSCOUT_SMOKE_MAX_HEALTH_AGE_MINUTES=5
SCHOLARSCOUT_SMOKE_TIMEOUT_MS=10000
SCHOLARSCOUT_SMOKE_RETRIES=1
SCHOLARSCOUT_SMOKE_MAX_LATENCY_MS=
